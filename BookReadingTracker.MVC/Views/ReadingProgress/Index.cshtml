@model ProgressListViewModel
@{
    ViewData["Title"] = "Reading Progress";
}

<div class="space-y-6">
    <div class="flex items-center justify-between">
        <h1 class="text-3xl font-bold tracking-tight">Reading Progress</h1>
        <div class="flex gap-2">
            <a asp-action="Index" asp-route-status=""
               class="inline-flex items-center justify-center rounded-md text-sm font-medium transition-colors h-9 px-3 @(string.IsNullOrEmpty(Model.StatusFilter) ? "bg-primary text-primary-foreground" : "border hover:bg-accent")">
                All
            </a>
            <a asp-action="Index" asp-route-status="Reading"
               class="inline-flex items-center justify-center rounded-md text-sm font-medium transition-colors h-9 px-3 @(Model.StatusFilter == "Reading" ? "bg-primary text-primary-foreground" : "border hover:bg-accent")">
                Reading
            </a>
            <a asp-action="Index" asp-route-status="Completed"
               class="inline-flex items-center justify-center rounded-md text-sm font-medium transition-colors h-9 px-3 @(Model.StatusFilter == "Completed" ? "bg-primary text-primary-foreground" : "border hover:bg-accent")">
                History
            </a>
        </div>
    </div>

    @if (!Model.Items.Any())
    {
        <div class="rounded-lg border bg-card p-12 text-center">
            <p class="text-muted-foreground">
                @if (Model.StatusFilter == "Completed")
                {
                    <span>No completed books yet.</span>
                }
                else
                {
                    <span>No reading progress found. Start by adding books to your reading list!</span>
                }
            </p>
        </div>
    }
    else
    {
        <div class="rounded-lg border bg-card">
            <div class="overflow-x-auto">
                <table class="w-full">
                    <thead>
                        <tr class="border-b bg-muted/50">
                            <th class="px-4 py-3 text-left text-sm font-medium">Book</th>
                            <th class="px-4 py-3 text-center text-sm font-medium">Status</th>
                            <th class="px-4 py-3 text-right text-sm font-medium">Progress</th>
                            <th class="px-4 py-3 text-right text-sm font-medium">Pages</th>
                            <th class="px-4 py-3 text-right text-sm font-medium">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Items)
                        {
                            <tr class="border-b last:border-0 hover:bg-muted/50 transition-colors">
                                <td class="px-4 py-3 text-sm font-medium">
                                    <a asp-controller="Book" asp-action="Detail" asp-route-id="@item.BookId" class="hover:underline">@item.Title</a>
                                    <div class="text-xs text-muted-foreground">@item.Author</div>
                                </td>
                                <td class="px-4 py-3 text-center">
                                    @{
                                        var statusColor = item.Status switch
                                        {
                                            "Completed" => "bg-green-50 text-green-700 border-green-200",
                                            "Reading" => "bg-blue-50 text-blue-700 border-blue-200",
                                            _ => "bg-gray-50 text-gray-700 border-gray-200"
                                        };
                                    }
                                    <span class="inline-flex items-center rounded-full border px-2.5 py-0.5 text-xs font-medium @statusColor">
                                        @item.Status
                                    </span>
                                </td>
                                <td class="px-4 py-3">
                                    <div class="flex items-center justify-end gap-2">
                                        <span class="text-sm font-medium">@item.ProgressPercent%</span>
                                        <div class="w-24 h-2 rounded-full bg-muted overflow-hidden">
                                            <div class="h-full rounded-full @(item.Status == "Completed" ? "bg-green-500" : "bg-blue-500")" style="width: @item.ProgressPercent%"></div>
                                        </div>
                                    </div>
                                </td>
                                <td class="px-4 py-3 text-sm text-right text-muted-foreground">
                                    @item.CurrentPage / @item.TotalPages
                                </td>
                                <td class="px-4 py-3 text-right">
                                    @if (item.Status != "Completed")
                                    {
                                        <form asp-action="Update" asp-route-id="@item.ReadingProgressId" method="post" class="flex items-center justify-end gap-2">
                                            <input type="number" name="CurrentPage" value="@item.CurrentPage" min="0" max="@item.TotalPages"
                                                   class="w-20 h-8 rounded-md border border-input bg-background px-2 py-1 text-xs ring-offset-background focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring" />
                                            <button type="submit"
                                                    class="inline-flex items-center justify-center rounded-md text-sm font-medium transition-colors h-8 px-3 border hover:bg-accent">
                                                Update
                                            </button>
                                        </form>
                                    }
                                    else
                                    {
                                        @if (item.CompletedDate.HasValue)
                                        {
                                            <span class="text-xs text-muted-foreground">Completed @item.CompletedDate.Value.ToString("MMM dd, yyyy")</span>
                                        }
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>
