@model GetUserDashboardResponse
@{
    ViewData["Title"] = "My Dashboard";
}

<div class="space-y-6">
    <h1 class="text-3xl font-bold tracking-tight">My Dashboard</h1>

    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-5">
        <div class="rounded-lg border bg-card text-card-foreground shadow-sm p-6">
            <p class="text-sm text-muted-foreground mb-1">Total Books Added</p>
            <p class="text-3xl font-bold">@Model.TotalBooksAdded</p>
        </div>
        <div class="rounded-lg border bg-card text-card-foreground shadow-sm p-6">
            <p class="text-sm text-muted-foreground mb-1">Currently Reading</p>
            <p class="text-3xl font-bold">@Model.CurrentlyReading</p>
        </div>
        <div class="rounded-lg border bg-card text-card-foreground shadow-sm p-6">
            <p class="text-sm text-muted-foreground mb-1">Completed Books</p>
            <p class="text-3xl font-bold">@Model.CompletedBooks</p>
        </div>
        <div class="rounded-lg border bg-card text-card-foreground shadow-sm p-6">
            <p class="text-sm text-muted-foreground mb-1">Pages Read</p>
            <p class="text-3xl font-bold">@Model.TotalPagesRead</p>
        </div>
        <div class="rounded-lg border bg-card text-card-foreground shadow-sm p-6">
            <p class="text-sm text-muted-foreground mb-1">Overall Progress</p>
            <p class="text-3xl font-bold">@Model.OverallProgressPercent%</p>
        </div>
    </div>

    @if (Model.TotalBooksAdded > 0)
    {
        <div class="rounded-lg border bg-card shadow-sm p-6">
            <h2 class="font-semibold mb-4">Progress Overview</h2>
            <div class="space-y-3">
                <div>
                    <div class="flex justify-between text-sm mb-1">
                        <span>Completed (@Model.CompletedBooks)</span>
                        <span class="text-muted-foreground">
                            @(Model.TotalBooksAdded > 0 ? Math.Round((decimal)Model.CompletedBooks / Model.TotalBooksAdded * 100, 1) : 0)%
                        </span>
                    </div>
                    <div class="h-2 rounded-full bg-muted overflow-hidden">
                        <div class="h-full rounded-full bg-green-500" style="width: @(Model.TotalBooksAdded > 0 ? Math.Round((double)Model.CompletedBooks / Model.TotalBooksAdded * 100) : 0)%"></div>
                    </div>
                </div>
                <div>
                    <div class="flex justify-between text-sm mb-1">
                        <span>Reading (@Model.CurrentlyReading)</span>
                        <span class="text-muted-foreground">
                            @(Model.TotalBooksAdded > 0 ? Math.Round((decimal)Model.CurrentlyReading / Model.TotalBooksAdded * 100, 1) : 0)%
                        </span>
                    </div>
                    <div class="h-2 rounded-full bg-muted overflow-hidden">
                        <div class="h-full rounded-full bg-blue-500" style="width: @(Model.TotalBooksAdded > 0 ? Math.Round((double)Model.CurrentlyReading / Model.TotalBooksAdded * 100) : 0)%"></div>
                    </div>
                </div>
                <div>
                    <div class="flex justify-between text-sm mb-1">
                        <span>Not Started (@Model.NotStarted)</span>
                        <span class="text-muted-foreground">
                            @(Model.TotalBooksAdded > 0 ? Math.Round((decimal)Model.NotStarted / Model.TotalBooksAdded * 100, 1) : 0)%
                        </span>
                    </div>
                    <div class="h-2 rounded-full bg-muted overflow-hidden">
                        <div class="h-full rounded-full bg-gray-400" style="width: @(Model.TotalBooksAdded > 0 ? Math.Round((double)Model.NotStarted / Model.TotalBooksAdded * 100) : 0)%"></div>
                    </div>
                </div>
            </div>
        </div>
    }

    @if (Model.TotalBooksAdded > 0)
    {
        <div class="rounded-lg border bg-card shadow-sm p-6">
            <h2 class="font-semibold mb-4">Achievements</h2>
            <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-4">
                <div class="flex items-center gap-3 rounded-lg border p-4 @(Model.AchievementFirstBook ? "" : "opacity-30")">
                    <span class="text-2xl">📖</span>
                    <div>
                        <p class="text-sm font-medium">First Book Finished</p>
                        <p class="text-xs text-muted-foreground">Complete your first book</p>
                    </div>
                </div>
                <div class="flex items-center gap-3 rounded-lg border p-4 @(Model.AchievementFiveBooks ? "" : "opacity-30")">
                    <span class="text-2xl">📚</span>
                    <div>
                        <p class="text-sm font-medium">5 Books Completed</p>
                        <p class="text-xs text-muted-foreground">Finish 5 books</p>
                    </div>
                </div>
                <div class="flex items-center gap-3 rounded-lg border p-4 @(Model.AchievementSevenDays ? "" : "opacity-30")">
                    <span class="text-2xl">🔥</span>
                    <div>
                        <p class="text-sm font-medium">Read 7 Days in a Row</p>
                        <p class="text-xs text-muted-foreground">Read on 7 consecutive days</p>
                    </div>
                </div>
                <div class="flex items-center gap-3 rounded-lg border p-4 @(Model.AchievementThousandPages ? "" : "opacity-30")">
                    <span class="text-2xl">🚀</span>
                    <div>
                        <p class="text-sm font-medium">1000 Pages Read</p>
                        <p class="text-xs text-muted-foreground">Read 1000 total pages</p>
                    </div>
                </div>
            </div>
            @if (!string.IsNullOrEmpty(Model.Badge))
            {
                <div class="mt-4 flex items-center gap-3 rounded-lg border border-yellow-200 bg-yellow-50 p-4">
                    <span class="text-3xl">@Model.Badge</span>
                </div>
            }
        </div>
    }

    @if (Model.TotalBooksAdded == 0)
    {
        <div class="rounded-lg border bg-card p-12 text-center">
            <p class="text-muted-foreground mb-4">You haven't added any books yet.</p>
            <a asp-controller="Book" asp-action="Index"
               class="inline-flex items-center justify-center rounded-md text-sm font-medium transition-colors h-10 px-4 bg-primary text-primary-foreground hover:bg-primary/90">
                Browse Books
            </a>
        </div>
    }
</div>
