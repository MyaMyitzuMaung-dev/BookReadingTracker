@model ChangePasswordViewModel
@{
    ViewData["Title"] = "Change Password";
}

<div class="flex items-center justify-center py-12">
    <div class="w-full max-w-md">
        <div class="rounded-lg border bg-card text-card-foreground shadow-sm">
            <div class="p-6 space-y-1">
                <h2 class="text-2xl font-semibold text-center">Change Password</h2>
                <p class="text-sm text-muted-foreground text-center">Update your account password</p>
            </div>
            <div class="p-6 pt-0">
                <form asp-action="ChangePassword" method="post" class="space-y-4">
                    <div class="space-y-2">
                        <label asp-for="OldPassword" class="text-sm font-medium">Current Password</label>
                        <input asp-for="OldPassword" type="password" class="flex h-10 w-full rounded-md border border-input bg-background px-3 py-2 text-sm ring-offset-background focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring" />
                        <span asp-validation-for="OldPassword" class="text-xs text-destructive"></span>
                    </div>
                    <div class="space-y-2">
                        <label asp-for="NewPassword" class="text-sm font-medium">New Password</label>
                        <input asp-for="NewPassword" type="password" class="flex h-10 w-full rounded-md border border-input bg-background px-3 py-2 text-sm ring-offset-background focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring" />
                        <span asp-validation-for="NewPassword" class="text-xs text-destructive"></span>
                    </div>
                    <div class="space-y-2">
                        <label asp-for="ConfirmPassword" class="text-sm font-medium">Confirm Password</label>
                        <input asp-for="ConfirmPassword" type="password" class="flex h-10 w-full rounded-md border border-input bg-background px-3 py-2 text-sm ring-offset-background focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring" />
                        <span asp-validation-for="ConfirmPassword" class="text-xs text-destructive"></span>
                    </div>
                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="rounded-lg border border-red-200 bg-red-50 p-3 text-sm text-red-800">
                            @Html.ValidationSummary(true, "", new { @class = "text-sm" })
                        </div>
                    }
                    <button type="submit" class="w-full inline-flex items-center justify-center rounded-md text-sm font-medium transition-colors h-10 px-4 bg-primary text-primary-foreground hover:bg-primary/90">
                        Update Password
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
